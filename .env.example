# =============================================================================
# My Gang - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# -----------------------------------------------------------------------------
# Dodo Payments
# -----------------------------------------------------------------------------
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_PAYMENTS_WEBHOOK_KEY=whsec_your-webhook-signing-key
DODO_PRODUCT_BASIC=pdt_your-basic-product-id
DODO_PRODUCT_PRO=pdt_your-pro-product-id
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Return URL after checkout — set to your production domain on Vercel
# Dodo appends ?subscription_id=...&status=... to this URL
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/checkout/success
# Client-side SDK mode (test or live_mode)
NEXT_PUBLIC_DODO_ENV=test_mode

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
# Canonical site URL used for metadata, auth redirects, sitemap, and status output.
# Set this to your deployed domain in preview/production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (recommended for auth abuse protection)
# -----------------------------------------------------------------------------
# Add "localhost" to your Turnstile widget hostnames or use Cloudflare test keys
# if you want the widget to work during local development.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# -----------------------------------------------------------------------------
# Admin Panel
# -----------------------------------------------------------------------------
ADMIN_PANEL_EMAIL=admin@example.com
# PBKDF2 hash in the format salt_hex:derived_key_hex.
# Example generator:
# node -e "const crypto=require('crypto'); const password=process.argv[1]; const salt=crypto.randomBytes(16).toString('hex'); const key=crypto.pbkdf2Sync(password, Buffer.from(salt,'hex'), 100000, 64, 'sha512').toString('hex'); console.log(`${salt}:${key}`)" "your-admin-password"
ADMIN_PANEL_PASSWORD_HASH=your-salt-hex:your-derived-key-hex
ADMIN_PANEL_SESSION_SECRET=random-32-char-secret-for-sessions

# Optional: plain-text password used only by Playwright admin login tests.
ADMIN_TEST_PASSWORD=your-admin-password

# -----------------------------------------------------------------------------
# Rate Limiting (Upstash Redis) — required in production
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# Background jobs / optional diagnostics
# -----------------------------------------------------------------------------
CRON_SECRET=your-long-random-cron-secret
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-site-verification-token
